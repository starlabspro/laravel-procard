{
    "name": "starlabspro/laravel-procard",
    "description": "Procard (ProcardPay Dispatcher) payment integration for Laravel",
    "keywords": [
        "Starlabs",
        "laravel",
        "laravel-procard",
        "procard",
        "procardpay"
    ],
    "homepage": "https://github.com/starlabspro/laravel-procard",
    "license": "MIT",
    "authors": [
        {
            "name": "Njazi Shehu",
            "email": "njazi@starlabspro.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0||^11.0||^12.0",
        "illuminate/http": "^10.0||^11.0||^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^7.0||^8.0",
        "larastan/larastan": "^2.0||^3.0",
        "orchestra/testbench": "^8.0||^9.0||^10.0",
        "pestphp/pest": "^2.0||^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^2.0||^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^1.0||^2.0",
        "phpstan/phpstan-phpunit": "^1.0||^2.0"
    },
    "autoload": {
        "psr-4": {
            "Starlabs\\LaravelProcard\\": "src/",
            "Starlabs\\LaravelProcard\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Starlabs\\LaravelProcard\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Starlabs\\LaravelProcard\\LaravelProcardServiceProvider"
            ],
            "aliases": {
                "LaravelProcard": "Starlabs\\LaravelProcard\\Facades\\LaravelProcard"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
